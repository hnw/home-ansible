GA_CLIENT_ID={{ ga_client_id | mandatory("Error: Variable 'ga_client_id' is undefined. Please define it in vars/vault.yml or host_vars.") }}
GA_CLIENT_SECRET={{ ga_client_secret | mandatory("Error: Variable 'ga_client_secret' is undefined. Please define it in vars/vault.yml or host_vars.") }}
GA_REFRESH_TOKEN={{ ga_refresh_token | mandatory("Error: Variable 'ga_refresh_token' is undefined. Please define it in vars/vault.yml or host_vars.") }}

GA_DEVICE_ID={{ ga_device_id | default("default") }}
GA_DEVICE_MODEL_ID={{ ga_device_model_id | default("default") }}
GA_LANGUAGE={{ ga_language | default("ja-JP") }}

PORT={{ ga_port | default("8080") }}
