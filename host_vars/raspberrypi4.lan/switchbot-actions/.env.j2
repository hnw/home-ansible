GAPROXY_CLIENT_ID={{ gaproxy_client_id | mandatory("Error: Variable 'gaproxy_client_id' is undefined. Please define it in vars/vault.yml or host_vars.") }}
GAPROXY_CLIENT_SECRET={{ gaproxy_client_secret | mandatory("Error: Variable 'gaproxy_client_secret' is undefined. Please define it in vars/vault.yml or host_vars.") }}
GAPROXY_REFRESH_TOKEN={{ gaproxy_refresh_token | mandatory("Error: Variable 'gaproxy_refresh_token' is undefined. Please define it in vars/vault.yml or host_vars.") }}

GAPROXY_DEVICE_ID={{ gaproxy_device_id | default("default") }}
GAPROXY_DEVICE_MODEL_ID={{ gaproxy_device_model_id | default("default") }}
